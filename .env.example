# Wanderlight environment scaffold (P0-INFRA-05).
# Copy to `.env` for local dev. NEVER commit real secrets — `.env` is gitignored.

# --- Analytics: PostHog (P0-ANL-01) ---
# Server-side (posthog-node). Wiring is guarded: set the key AND `npm i posthog-node` to activate.
POSTHOG_KEY=
POSTHOG_HOST=https://eu.posthog.com
# Client-side (posthog-js). Vite only exposes VITE_-prefixed vars to the browser bundle.
# Guarded: set the key AND `npm i posthog-js` (in client/) to activate; else analytics no-ops.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.posthog.com

# --- Error tracking: Sentry (P0-INFRA-06) ---
# Guarded: set the DSN AND `npm i @sentry/node` (in server/) to activate; else error reporting no-ops.
SENTRY_DSN=

# --- Database: Postgres (used from P1) ---
DATABASE_URL=

# --- Server ---
PORT=3000
